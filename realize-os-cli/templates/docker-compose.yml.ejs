# =============================================================================
# RealizeOS 5 — Docker Compose Configuration
# =============================================================================
# Generated by: npx realize-os init
# Project: <%= projectName %>
# =============================================================================

services:
  api:
    image: <%= image %>
<% if (withGws) { %>
    build:
      args:
        INSTALL_GWS: "true"
<% } %>
    container_name: realizeos-api
    ports:
      - "${REALIZE_PORT:-<%= port %>}:<%= port %>"
    volumes:
      # Named volumes for persistent storage
      - realize-data:/app/data
      - realize-shared:/app/shared
      # Bind mounts for user-editable config
      - ./realize-os.yaml:/app/realize-os.yaml:ro
      - ./systems:/app/systems
      - ./.credentials:/app/.credentials:ro
    env_file:
      - .env
    environment:
      - DATA_DIR=/app/data
      - KB_PATH=/app
      - REALIZE_HOST=0.0.0.0
      - REALIZE_PORT=<%= port %>
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:<%= port %>/health"]
      interval: 30s
      timeout: 10s
      start_period: 15s
      retries: 3

<% if (withTelegram) { %>
  # ---------------------------------------------------------------------------
  # Telegram Bot
  # ---------------------------------------------------------------------------
  telegram:
    image: <%= image %>
    container_name: realizeos-telegram
    command: python cli.py bot
    volumes:
      - realize-data:/app/data
      - realize-shared:/app/shared
      - ./realize-os.yaml:/app/realize-os.yaml:ro
      - ./systems:/app/systems
      - ./.credentials:/app/.credentials:ro
    env_file:
      - .env
    environment:
      - DATA_DIR=/app/data
      - KB_PATH=/app
    depends_on:
      api:
        condition: service_healthy
    restart: unless-stopped
<% } %>

# =============================================================================
# Named Volumes — Docker-managed persistent storage
# =============================================================================
volumes:
  realize-data:
    name: realizeos-data
    driver: local
    labels:
      com.realizeos.description: "SQLite database and operational data"

  realize-shared:
    name: realizeos-shared
    driver: local
    labels:
      com.realizeos.description: "Shared knowledge base content across ventures"
