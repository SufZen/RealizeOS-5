# RealizeOS Environment Variables
# Generated by: npx realize-os init
# NEVER commit this file to version control.

# --- LLM API Keys (at least one required) ---
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# --- Additional LLM Providers (optional) ---
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# --- Telegram Bot (optional) ---
TELEGRAM_BOT_TOKEN=

# --- Web Search (optional) ---
BRAVE_API_KEY=

<% if (withGws) { %>
# --- Google Workspace (optional — for email, calendar, drive) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
<% } else { %>
# --- Google Workspace (uncomment to enable) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
<% } %>

# --- Browser Automation (optional) ---
BROWSER_ENABLED=false

# --- MCP Servers (optional) ---
MCP_ENABLED=false

# --- API Server ---
REALIZE_HOST=127.0.0.1
REALIZE_PORT=<%= port %>
REALIZE_API_KEY=
CORS_ORIGINS=*

# --- Paths ---
KB_PATH=.
DATA_PATH=./data
REALIZE_CONFIG=realize-os.yaml

# --- Rate Limits ---
RATE_LIMIT_PER_MINUTE=30
COST_LIMIT_PER_HOUR_USD=5.00
