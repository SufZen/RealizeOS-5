# RealizeOS Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- LLM API Keys (at least one required) ---
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# --- Additional LLM Providers (optional) ---
# OPENAI_API_KEY=                # Enables GPT-4o routing
# OLLAMA_BASE_URL=http://localhost:11434  # Enables local Ollama models

# --- Telegram Bot (optional — for Telegram channel) ---
TELEGRAM_BOT_TOKEN=

# --- Web Search (optional — for web research capabilities) ---
BRAVE_API_KEY=

# --- Google Workspace (optional — for email, calendar, drive) ---
# Run the OAuth setup flow: python cli.py setup-google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Browser Automation (optional) ---
BROWSER_ENABLED=false

# --- MCP Servers (optional — for advanced tool integrations) ---
MCP_ENABLED=false

# --- API Server ---
REALIZE_HOST=127.0.0.1
REALIZE_PORT=8080
REALIZE_API_KEY=       # Set a strong API key for the REST API
CORS_ORIGINS=*         # Comma-separated allowed origins

# --- Paths (optional — override defaults) ---
KB_PATH=.                      # Root path for knowledge base files
DATA_PATH=./data               # Path for data storage (sessions, memory)
REALIZE_CONFIG=realize-os.yaml # Path to config file

# --- Model Overrides (optional — override default model IDs) ---
# GEMINI_FLASH_MODEL=gemini-2.0-flash
# CLAUDE_SONNET_MODEL=claude-sonnet-4-6-20250610
# CLAUDE_OPUS_MODEL=claude-opus-4-6-20250610

# --- Rate Limits ---
RATE_LIMIT_PER_MINUTE=30
COST_LIMIT_PER_HOUR_USD=5.00
