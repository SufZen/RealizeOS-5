# ============================================================
# RealizeOS V5 — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your keys.
# Only the keys you use need values — the system auto-discovers providers.

# === LLM Providers ===
# At least one provider is required for the system to function.

# Anthropic (Claude models — recommended for content creation)
ANTHROPIC_API_KEY=

# Google AI (Gemini models — recommended for fast/simple tasks)
GOOGLE_AI_API_KEY=

# OpenAI (GPT models)
OPENAI_API_KEY=

# Ollama (local models — no API key needed, just the base URL)
OLLAMA_BASE_URL=http://localhost:11434


# === API Security ===
# Set this to require API key authentication for all requests.
# Leave empty for local-only, no-auth mode.
REALIZE_API_KEY=

# JWT Authentication (for multi-user setups)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60


# === Channels ===

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# Web Search — Brave API (optional, enables web_search tool)
BRAVE_API_KEY=


# === Cloud Storage (S3-compatible) ===
# Configure to sync FABRIC data across devices or for cloud backup.
# Works with AWS S3, MinIO, DigitalOcean Spaces, Backblaze B2, Cloudflare R2.
# Leave empty to use local storage only (default).

S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=
# Examples:
#   AWS S3:           (leave S3_ENDPOINT_URL empty)
#   MinIO:            http://localhost:9000
#   DO Spaces:        https://nyc3.digitaloceanspaces.com
#   Backblaze B2:     https://s3.us-west-004.backblazeb2.com
#   Cloudflare R2:    https://<account_id>.r2.cloudflarestorage.com


# === Database ===
# SQLite is used by default. No configuration needed for local use.
# DATABASE_URL=sqlite:///realizeos.db


# === Server ===
HOST=0.0.0.0
PORT=8080
# DEBUG=false
